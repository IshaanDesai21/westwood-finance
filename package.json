{
  "name": "westwood-finance",
  "version": "1.0.0",
  "description": "Finance management for Westwood Robotics",
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node src/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "concurrently --names \"API,WEB\" --prefix-colors \"yellow,cyan\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && node src/index.js",
    "start:frontend": "cd frontend && node build",
    "preview": "npm run build && npm run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "license": "ISC",
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.10"
  }
}
